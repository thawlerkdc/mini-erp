# Ambiente de homologacao (nao versionar o .env.homolog real)
APP_ENV=homolog
FLASK_ENV=production

# Gere uma chave propria para homologacao
SECRET_KEY=change-me-homolog-secret-key

# Use banco separado da producao
DATABASE_URL=postgresql://user:password@localhost:5432/mini_erp_homolog

# Opcional para dados locais persistentes
# DATA_DIR=./data-homolog
