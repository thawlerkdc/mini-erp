# Ambiente de producao (nao versionar o .env.production real)
APP_ENV=production
FLASK_ENV=production

# Gere uma chave propria para producao
SECRET_KEY=change-me-production-secret-key

# Banco oficial de producao
DATABASE_URL=postgresql://user:password@host:5432/mini_erp_prod

# Opcional para dados locais persistentes
# DATA_DIR=./data-prod
